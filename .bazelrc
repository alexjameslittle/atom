build --java_runtime_version=remotejdk_21

build --@rules_rust//rust/settings:rustfmt.toml=//:rustfmt.toml

# Linting via aspect_rules_lint
build:lint --aspects=//tools/lint:linters.bzl%clippy

# BuildBuddy remote cache
build:buildbuddy --bes_results_url=https://app.buildbuddy.io/invocation/
build:buildbuddy --bes_backend=grpcs://remote.buildbuddy.io
build:buildbuddy --remote_cache=grpcs://remote.buildbuddy.io
build:buildbuddy --remote_cache_compression
build:buildbuddy --bes_upload_mode=fully_async
build:buildbuddy --remote_timeout=3600

# API key is set via user.bazelrc (local dev) or CI env
# Try importing local user config (generated by scripts/setup-buildbuddy.sh)
try-import %workspace%/user.bazelrc
