package {{ package_name }}

import android.app.Application
import android.util.Log

class AtomApplication : Application() {
    var runtimeInitialized = false
        private set

    override fun onCreate() {
        super.onCreate()
        System.loadLibrary("atom_runtime_jni")
        val initStatus = AtomRuntimeBridge.initRuntime()
        runtimeInitialized = initStatus == 0
        if (!runtimeInitialized) {
            Log.e(TAG, "atom_app_init failed")
        } else {
            Log.i(TAG, "Booting {{ name }} ({{ slug }}) on Android")
            Log.i(TAG, "Modules: ${AtomBindings.moduleSummary}")
        }
    }

    override fun onTerminate() {
        if (runtimeInitialized) {
            AtomRuntimeBridge.handleLifecycle(5)
            AtomRuntimeBridge.shutdown()
            runtimeInitialized = false
        }
        super.onTerminate()
    }

    fun sendLifecycle(event: Int, action: String) {
        if (!runtimeInitialized) return
        val result = AtomRuntimeBridge.handleLifecycle(event)
        if (result != 0) {
            Log.e(TAG, "$action transition failed with code $result")
        }
    }

    companion object {
        const val TAG = "AtomRuntime"
    }
}

object AtomRuntimeBridge {
    external fun initRuntime(): Int
    external fun handleLifecycle(event: Int): Int
    external fun shutdown()
}
