private enum AtomAutomationElement: String {
    case title = "atom.fixture.title"
    case slug = "atom.fixture.slug"
    case status = "atom.fixture.status"
    case input = "atom.fixture.input"
    case button = "atom.fixture.primary_button"
    case echo = "atom.fixture.echo"
}

private final class AtomAutomationState: ObservableObject {
    @Published var statusText = "ready"
    @Published var inputText = ""
    @Published var echoText = "Typed: "
    @Published var tapCount = 0
    var screenSize = CGSize(width: 393, height: 852)

    func snapshot() -> [String: Any] {
        let width = max(Double(screenSize.width), 1)
        let height = max(Double(screenSize.height), 1)

        return [
            "screen": [
                "width": width,
                "height": height,
            ],
            "nodes": [
                node(
                    id: AtomAutomationElement.title.rawValue,
                    role: "text",
                    label: "{{ name }}",
                    text: "{{ name }}",
                    x: 24,
                    y: 112,
                    width: width - 48,
                    height: 32
                ),
                node(
                    id: AtomAutomationElement.slug.rawValue,
                    role: "text",
                    label: "{{ slug }}",
                    text: "{{ slug }}",
                    x: 24,
                    y: 156,
                    width: width - 48,
                    height: 20
                ),
                node(
                    id: AtomAutomationElement.status.rawValue,
                    role: "text",
                    label: statusText,
                    text: statusText,
                    x: 24,
                    y: 204,
                    width: width - 48,
                    height: 24
                ),
                node(
                    id: AtomAutomationElement.input.rawValue,
                    role: "text_field",
                    label: "Automation Input",
                    text: inputText,
                    x: 24,
                    y: 264,
                    width: width - 48,
                    height: 44
                ),
                node(
                    id: AtomAutomationElement.button.rawValue,
                    role: "button",
                    label: "Primary Action",
                    text: "Primary Action",
                    x: 24,
                    y: 324,
                    width: width - 48,
                    height: 50
                ),
                node(
                    id: AtomAutomationElement.echo.rawValue,
                    role: "text",
                    label: echoText,
                    text: echoText,
                    x: 24,
                    y: 394,
                    width: width - 48,
                    height: 24
                ),
            ],
        ]
    }

    func apply(command: [String: Any]) -> [String: Any] {
        let kind = command["kind"] as? String ?? "unknown"
        let targetId = command["target_id"] as? String
        let x = command["x"] as? Double
        let y = command["y"] as? Double
        let text = command["text"] as? String

        switch kind {
        case "inspect_ui":
            break
        case "tap":
            handleTap(targetId: targetId, x: x, y: y, isLongPress: false)
        case "long_press":
            handleTap(targetId: targetId, x: x, y: y, isLongPress: true)
        case "type_text":
            if targetId == nil || targetId == AtomAutomationElement.input.rawValue {
                inputText = text ?? ""
                echoText = "Typed: \(inputText)"
                statusText = "typed-text"
            } else {
                statusText = "unsupported-text-target"
            }
        case "swipe":
            statusText = "swipe(\(formatPoint(x: x, y: y)))"
        case "drag":
            statusText = "drag(\(formatPoint(x: x, y: y)))"
        default:
            statusText = "unknown-command"
        }

        return snapshot()
    }

    private func handleTap(targetId: String?, x: Double?, y: Double?, isLongPress: Bool) {
        let resolvedTarget = targetId ?? resolveTargetId(x: x, y: y)
        switch resolvedTarget {
        case AtomAutomationElement.button.rawValue:
            tapCount += 1
            let action = isLongPress ? "long-pressed" : "tapped"
            statusText = "primary-button-\(action)-\(tapCount)"
        case AtomAutomationElement.input.rawValue:
            statusText = isLongPress ? "input-long-press" : "input-focused"
        default:
            statusText = "tap-unmapped"
        }
    }

    private func resolveTargetId(x: Double?, y: Double?) -> String? {
        guard let x, let y else {
            return nil
        }
        let snapshot = snapshot()
        guard let nodes = snapshot["nodes"] as? [[String: Any]] else {
            return nil
        }
        for node in nodes {
            guard
                let id = node["id"] as? String,
                let bounds = node["bounds"] as? [String: Any],
                let nodeX = bounds["x"] as? Double,
                let nodeY = bounds["y"] as? Double,
                let width = bounds["width"] as? Double,
                let height = bounds["height"] as? Double
            else {
                continue
            }
            if x >= nodeX && x <= nodeX + width && y >= nodeY && y <= nodeY + height {
                return id
            }
        }
        return nil
    }

    private func node(
        id: String,
        role: String,
        label: String,
        text: String,
        x: Double,
        y: Double,
        width: Double,
        height: Double
    ) -> [String: Any] {
        [
            "id": id,
            "role": role,
            "label": label,
            "text": text,
            "visible": true,
            "enabled": true,
            "bounds": [
                "x": x,
                "y": y,
                "width": width,
                "height": height,
            ],
        ]
    }

    private func formatPoint(x: Double?, y: Double?) -> String {
        "\(x ?? 0),\(y ?? 0)"
    }
}

