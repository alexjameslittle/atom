private final class AtomAutomationClient {
    struct Config {
        let url: URL
        let token: String

        static func fromLaunchArguments() -> Config? {
            let arguments = ProcessInfo.processInfo.arguments
            guard
                let urlValue = value(named: "--atom-automation-url", in: arguments),
                let url = URL(string: urlValue),
                let token = value(named: "--atom-automation-token", in: arguments)
            else {
                return nil
            }
            return Config(url: url, token: token)
        }

        private static func value(named flag: String, in arguments: [String]) -> String? {
            guard let index = arguments.firstIndex(of: flag), index + 1 < arguments.count else {
                return nil
            }
            return arguments[index + 1]
        }
    }

    private let config: Config
    private let state: AtomAutomationState
    private let session = URLSession(configuration: .default)
    private var timer: Timer?

    init(config: Config, state: AtomAutomationState) {
        self.config = config
        self.state = state
    }

    func start() {
        register()
        timer = Timer.scheduledTimer(withTimeInterval: 0.25, repeats: true) { [weak self] _ in
            self?.poll()
        }
    }

    func stop() {
        timer?.invalidate()
        timer = nil
    }

    private func register() {
        post(
            path: "register",
            payload: [
                "token": config.token,
                "platform": "ios",
            ]
        )
    }

    private func poll() {
        guard let url = URL(string: "next?token=\(config.token)", relativeTo: config.url) else {
            return
        }
        let task = session.dataTask(with: url) { [weak self] data, response, _ in
            guard
                let self,
                let http = response as? HTTPURLResponse,
                http.statusCode == 200,
                let data,
                let object = try? JSONSerialization.jsonObject(with: data),
                let command = object as? [String: Any]
            else {
                return
            }
            Task { @MainActor in
                let snapshot = self.state.apply(command: command)
                self.post(
                    path: "result",
                    payload: [
                        "token": self.config.token,
                        "command_id": command["id"] as? String ?? "",
                        "ok": true,
                        "snapshot": snapshot,
                    ]
                )
            }
        }
        task.resume()
    }

    private func post(path: String, payload: [String: Any]) {
        guard let url = URL(string: path, relativeTo: config.url) else {
            return
        }
        var request = URLRequest(url: url)
        request.httpMethod = "POST"
        request.setValue("application/json", forHTTPHeaderField: "Content-Type")
        request.httpBody = try? JSONSerialization.data(withJSONObject: payload)
        let task = session.dataTask(with: request)
        task.resume()
    }
}
