    private inner class AutomationClient(
        private val baseUrl: String,
        private val token: String,
    ) {
        private val executor = Executors.newSingleThreadScheduledExecutor()

        fun start() {
            executor.execute {
                if (!postSafely("register", JSONObject()
                        .put("token", token)
                        .put("platform", "android"))) {
                    return@execute
                }
                executor.scheduleAtFixedRate({
                    pollSafely()
                }, 0, 250, TimeUnit.MILLISECONDS)
            }
        }

        fun stop() {
            executor.shutdownNow()
        }

        private fun pollSafely() {
            try {
                poll()
            } catch (_: Exception) {
                // Keep the app alive even if the host-side bridge is temporarily unavailable.
            }
        }

        private fun poll() {
            val connection = openConnection("next?token=${token}")
            connection.requestMethod = "GET"
            val status = connection.responseCode
            if (status != 200) {
                connection.disconnect()
                return
            }
            val payload = connection.inputStream.bufferedReader().use { it.readText() }
            connection.disconnect()
            val command = JSONObject(payload)
            mainHandler.post {
                val snapshot = handleAutomationCommand(command)
                executor.execute {
                    postSafely("result", JSONObject()
                        .put("token", token)
                        .put("command_id", command.optString("id"))
                        .put("ok", true)
                        .put("snapshot", snapshot))
                }
            }
        }

        private fun postSafely(path: String, payload: JSONObject): Boolean {
            return try {
                post(path, payload)
                true
            } catch (_: Exception) {
                mainHandler.post {
                    automationState.statusText = "automation-bridge-unavailable"
                    renderAutomationState()
                }
                false
            }
        }

        private fun post(path: String, payload: JSONObject) {
            val connection = openConnection(path)
            try {
                connection.requestMethod = "POST"
                connection.doOutput = true
                OutputStreamWriter(connection.outputStream).use { writer ->
                    writer.write(payload.toString())
                }
                connection.inputStream.close()
            } finally {
                connection.disconnect()
            }
        }

        private fun openConnection(path: String): HttpURLConnection {
            val url = URL("${baseUrl}${path}")
            return (url.openConnection() as HttpURLConnection).apply {
                connectTimeout = 2_000
                readTimeout = 2_000
                setRequestProperty("Content-Type", "application/json")
            }
        }

    }
