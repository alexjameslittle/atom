package {{ package_name }}

import android.app.Activity
import android.os.Bundle
import android.view.Gravity
import android.widget.LinearLayout
import android.widget.TextView

class MainActivity : Activity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        val layout = LinearLayout(this).apply {
            orientation = LinearLayout.VERTICAL
            gravity = Gravity.CENTER
            setPadding(48, 48, 48, 48)
        }
        layout.addView(TextView(this).apply {
            text = "{{ name }}"
            textSize = 24f
            gravity = Gravity.CENTER
        })
        layout.addView(TextView(this).apply {
            text = "{{ slug }}"
            textSize = 14f
            gravity = Gravity.CENTER
            alpha = 0.6f
        })
        layout.addView(TextView(this).apply {
            text = AtomBindings.moduleSummary
            textSize = 12f
            gravity = Gravity.CENTER
            alpha = 0.6f
        })
        setContentView(layout)

        atomApp?.sendLifecycle(1, "foreground")
    }

    override fun onResume() {
        super.onResume()
        atomApp?.sendLifecycle(1, "foreground")
    }

    override fun onPause() {
        atomApp?.sendLifecycle(2, "background")
        super.onPause()
    }

    override fun onDestroy() {
        atomApp?.sendLifecycle(5, "terminate")
        super.onDestroy()
    }

    private val atomApp: AtomApplication?
        get() = application as? AtomApplication
}
