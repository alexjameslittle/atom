    private fun renderAutomationState() {
        inputView.setText(automationState.inputText)
        statusView.text = automationState.statusText
        echoView.text = automationState.echoText
    }

    private fun snapshotJson(): JSONObject {
        val width = resources.displayMetrics.widthPixels.toDouble()
        val height = resources.displayMetrics.heightPixels.toDouble()
        val nodes = JSONArray()
        nodes.put(node(AutomationElement.TITLE.id, "text", "{{ name }}", "{{ name }}", 24.0, 112.0, width - 48.0, 32.0))
        nodes.put(node(AutomationElement.SLUG.id, "text", "{{ slug }}", "{{ slug }}", 24.0, 156.0, width - 48.0, 20.0))
        nodes.put(node(AutomationElement.STATUS.id, "text", automationState.statusText, automationState.statusText, 24.0, 204.0, width - 48.0, 24.0))
        nodes.put(node(AutomationElement.INPUT.id, "text_field", "Automation Input", automationState.inputText, 24.0, 264.0, width - 48.0, 56.0))
        nodes.put(node(AutomationElement.BUTTON.id, "button", "Primary Action", "Primary Action", 24.0, 336.0, width - 48.0, 50.0))
        nodes.put(node(AutomationElement.ECHO.id, "text", automationState.echoText, automationState.echoText, 24.0, 404.0, width - 48.0, 24.0))
        return JSONObject()
            .put("screen", JSONObject().put("width", width).put("height", height))
            .put("nodes", nodes)
    }

    private fun node(
        id: String,
        role: String,
        label: String,
        text: String,
        x: Double,
        y: Double,
        width: Double,
        height: Double,
    ): JSONObject {
        return JSONObject()
            .put("id", id)
            .put("role", role)
            .put("label", label)
            .put("text", text)
            .put("visible", true)
            .put("enabled", true)
            .put("bounds", JSONObject()
                .put("x", x)
                .put("y", y)
                .put("width", width)
                .put("height", height))
    }

    private fun handleAutomationCommand(command: JSONObject): JSONObject {
        val kind = command.optString("kind")
        val targetId = command.optString("target_id", null)
        val text = command.optString("text", null)
        val x = command.optDouble("x", Double.NaN)
        val y = command.optDouble("y", Double.NaN)

        when (kind) {
            "inspect_ui" -> Unit
            "tap" -> handleTap(targetId, x, y, false)
            "long_press" -> handleTap(targetId, x, y, true)
            "type_text" -> {
                if (targetId == null || targetId == AutomationElement.INPUT.id) {
                    automationState.inputText = text ?: ""
                    automationState.echoText = "Typed: ${automationState.inputText}"
                    automationState.statusText = "typed-text"
                } else {
                    automationState.statusText = "unsupported-text-target"
                }
                renderAutomationState()
            }
            "swipe" -> {
                automationState.statusText = "swipe(${pointText(x, y)})"
                renderAutomationState()
            }
            "drag" -> {
                automationState.statusText = "drag(${pointText(x, y)})"
                renderAutomationState()
            }
            else -> {
                automationState.statusText = "unknown-command"
                renderAutomationState()
            }
        }

        return snapshotJson()
    }

    private fun handleTap(targetId: String?, x: Double, y: Double, isLongPress: Boolean) {
        val resolvedTarget = targetId ?: resolveTargetId(x, y)
        when (resolvedTarget) {
            AutomationElement.BUTTON.id -> {
                automationState.tapCount += 1
                val action = if (isLongPress) "long-pressed" else "tapped"
                automationState.statusText = "primary-button-${action}-${automationState.tapCount}"
            }
            AutomationElement.INPUT.id -> {
                automationState.statusText = if (isLongPress) "input-long-press" else "input-focused"
            }
            else -> {
                automationState.statusText = "tap-unmapped"
            }
        }
        renderAutomationState()
    }

    private fun resolveTargetId(x: Double, y: Double): String? {
        val snapshot = snapshotJson().getJSONArray("nodes")
        for (index in 0 until snapshot.length()) {
            val node = snapshot.getJSONObject(index)
            val bounds = node.getJSONObject("bounds")
            val nodeX = bounds.getDouble("x")
            val nodeY = bounds.getDouble("y")
            val width = bounds.getDouble("width")
            val height = bounds.getDouble("height")
            if (!x.isNaN() && !y.isNaN() && x >= nodeX && x <= nodeX + width && y >= nodeY && y <= nodeY + height) {
                return node.getString("id")
            }
        }
        return null
    }

    private fun pointText(x: Double, y: Double): String {
        val safeX = if (x.isNaN()) 0.0 else x
        val safeY = if (y.isNaN()) 0.0 else y
        return "${safeX},${safeY}"
    }

